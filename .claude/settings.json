{
  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git stash *)",
      "Bash(git push *)",
      "Bash(gh run watch *)",
      "Bash(android *)",
      "Bash(actionlint *)",
      "Bash(adb devices)",
      "Bash(adb logcat *)",
      "Bash(adb shell am start *)",
      "mcp__figma__get_design_context",
      "Read(**)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push origin main*)",
      "Bash(git push origin main:*)",
      "Bash(git push * main*)",
      "Bash(git push * main:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/format-on-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/forbid-secrets.sh"
          }
        ]
      }
    ]
  }
}
